# ============================================================
# reserva-service - DEV environment template
# ------------------------------------------------------------
# Copy this file to .env (in this same folder) and load it
# from your IDE Run Configuration (e.g. EnvFile plugin in IntelliJ).
# Defaults in YAML are PROD-safe; this file overrides for DEV.
# ============================================================

# --- Spring Cloud Config Server ---
CONFIG_IMPORT=optional:configserver:http://localhost:8888
CONFIG_FAIL_FAST=false

# --- Server ---
SERVER_PORT=8083

# --- Eureka discovery ---
EUREKA_URL=http://localhost:8761/eureka

# --- Datasource (MySQL) ---
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3307/reserva_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# --- JPA (DEV verbose; YAML defaults are PROD-safe) ---
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# --- Kafka (producer to reserva.notifications, consumer of pago.events) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Topic has a default in YAML; override only if needed
# KAFKA_RESERVA_NOTIFICATIONS_TOPIC=reserva.notifications
# KAFKA_PAGO_EVENTS_TOPIC=pago.events
# KAFKA_RESERVA_CONSUMER_GROUP=reserva-service

# --- JWT (RSA public key validation) ---
# Same public key emitted by auth-service. PEM single-line with literal \n.
JWT_PUBLIC_KEY=

# --- Auth service (service-to-service via OAuth2 client_credentials) ---
# DEV: auth-service runs locally from IDE on port 8081
AUTH_SERVICE_URL=http://localhost:8081
# Must match RESERVA_SERVICE_CLIENT_ID/SECRET seeded in auth-service
AUTH_SERVICE_CLIENT_ID=
AUTH_SERVICE_CLIENT_SECRET=

# --- Hotel service (REST client) ---
# DEV: hotel-service runs locally from IDE on port 8082
HOTEL_SERVICE_URL=http://localhost:8082

# --- Pago service (SAGA orchestrator → ms-pago) ---
# DEV: pago-service runs locally from IDE on port 8085
PAGO_SERVICE_URL=http://localhost:8085

# --- Pago URLs (Stripe Checkout return) ---
PAGO_DEFAULT_CURRENCY=USD
PAGO_SUCCESS_URL=http://localhost:4200/reservas/success
PAGO_CANCEL_URL=http://localhost:4200/reservas/cancel

# --- Job de expiracion de reservas PENDIENTE_PAGO ---
# JOBS_EXPIRAR_RESERVAS_FIXED_DELAY_MS=30000
# JOBS_EXPIRAR_RESERVAS_INITIAL_DELAY_MS=30000

# --- CORS (DEV: Angular dev server) ---
CORS_ALLOWED_ORIGINS=http://localhost:4200
